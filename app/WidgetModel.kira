Widget SurfacePaddingLayer(value: Float) {
    @Content let content: Widget

    function lower(context: borrow KiraUIFoundation.FoundationUiContext) -> KiraUIFoundation.FoundationView {
        return viewWithSurfacePadding(content.lower(context), value)
    }
}

Widget WidthLayer(value: Float) {
    @Content let content: Widget

    function lower(context: borrow KiraUIFoundation.FoundationUiContext) -> KiraUIFoundation.FoundationView {
        return viewWithWidth(content.lower(context), KiraUIFoundation.SizeMode.Fixed(value))
    }
}

Widget FillHeightLayer() {
    @Content let content: Widget

    function lower(context: borrow KiraUIFoundation.FoundationUiContext) -> KiraUIFoundation.FoundationView {
        return viewWithHeight(content.lower(context), KiraUIFoundation.SizeMode.Fill)
    }
}

Widget HeightLayer(value: Float) {
    @Content let content: Widget

    function lower(context: borrow KiraUIFoundation.FoundationUiContext) -> KiraUIFoundation.FoundationView {
        return viewWithHeight(content.lower(context), KiraUIFoundation.SizeMode.Fixed(value))
    }
}

Widget Text(content: String) {
    function lower(context: borrow KiraUIFoundation.FoundationUiContext) -> KiraUIFoundation.FoundationView {
        let ignored = context.frameCount
        return KiraUIFoundation.FoundationView {
            kind: KiraUIFoundation.FoundationViewKind.Text
            content: content
            color: defaultTextColor()
            size: 16.0
            weight: 400.0
        }
    }
}

Widget AppSurface(padding: Float) {
    @Content let content: Widget

    function lower(context: borrow KiraUIFoundation.FoundationUiContext) -> KiraUIFoundation.FoundationView {
        return Surface(
            children: [content.lower(context)],
            width: KiraUIFoundation.SizeMode.Fill,
            height: KiraUIFoundation.SizeMode.Fill,
            flex: 0,
            fill: transparentFoundationColor(),
            border: transparentFoundationColor(),
            borderWidth: 0.0,
            radius: 0.0,
            shape: KiraUIFoundation.FoundationShape.RegularRoundedRect,
            material: KiraUIFoundation.FoundationMaterial.Flat,
            effects: [],
            padding: uniformInsets(padding),
            clipContent: false
        )
    }
}

Widget VStack(spacing: Float) {
    @Content let children: [Widget]

    function lower(context: borrow KiraUIFoundation.FoundationUiContext) -> KiraUIFoundation.FoundationView {
        return Column(
            children: loweredChildren(context, children),
            width: KiraUIFoundation.SizeMode.Fill,
            height: KiraUIFoundation.SizeMode.Hug,
            spacing: spacing,
            padding: KiraUIFoundation.EdgeInsets {},
            crossAxisAlignment: KiraUIFoundation.CrossAlignment.Start
        )
    }
}

Widget HStack(spacing: Float) {
    @Content let children: [Widget]

    function lower(context: borrow KiraUIFoundation.FoundationUiContext) -> KiraUIFoundation.FoundationView {
        return Row(
            children: loweredChildren(context, children),
            width: KiraUIFoundation.SizeMode.Fill,
            height: KiraUIFoundation.SizeMode.Hug,
            spacing: spacing,
            padding: KiraUIFoundation.EdgeInsets {},
            crossAxisAlignment: KiraUIFoundation.CrossAlignment.Center
        )
    }
}

Widget HStackStretch(spacing: Float) {
    @Content let children: [Widget]

    function lower(context: borrow KiraUIFoundation.FoundationUiContext) -> KiraUIFoundation.FoundationView {
        return Row(
            children: loweredChildren(context, children),
            width: KiraUIFoundation.SizeMode.Fill,
            height: KiraUIFoundation.SizeMode.Hug,
            spacing: spacing,
            padding: KiraUIFoundation.EdgeInsets {},
            crossAxisAlignment: KiraUIFoundation.CrossAlignment.Stretch
        )
    }
}

