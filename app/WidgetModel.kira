Widget LinearGradient(start: Color, end: Color) {
    function lower(context: borrow KiraUIFoundation.FoundationUiContext) -> KiraUIFoundation.FoundationView {
        let ignored = context.viewport.width
        var strips: [KiraUIFoundation.FoundationView] = []
        var index = 0
        while index < 12 {
            let ratio = intAsFloat(value: index) / 11.0
            let color = foundationColor(lerpColor(start, end, ratio))
            let strip = Surface(
                children: [],
                width: KiraUIFoundation.SizeMode.Fill,
                height: KiraUIFoundation.SizeMode.Fill,
                flex: 1,
                fill: move color,
                border: transparentFoundationColor(),
                borderWidth: 0.0,
                radius: 0.0,
                shape: KiraUIFoundation.FoundationShape.RegularRoundedRect,
                material: KiraUIFoundation.FoundationMaterial.Flat,
                effects: [],
                padding: KiraUIFoundation.EdgeInsets {},
                clipContent: false
            )
            strips.append(move strip)
            index = index + 1
        }
        return Column(
            children: move strips,
            width: KiraUIFoundation.SizeMode.Fill,
            height: KiraUIFoundation.SizeMode.Fill,
            spacing: 0.0,
            padding: KiraUIFoundation.EdgeInsets {},
            crossAxisAlignment: KiraUIFoundation.CrossAlignment.Stretch
        )
    }
}

