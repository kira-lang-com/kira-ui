function viewWithSurfacePadding(view: KiraUIFoundation.FoundationView, length: Float) -> KiraUIFoundation.FoundationView {
    return KiraUIFoundation.FoundationView {
        kind: view.kind
        key: view.key
        children: identityChildren(view.children)
        width: view.width
        height: view.height
        flex: view.flex
        gap: view.gap
        padding: uniformInsets(length)
        crossAxisAlignment: view.crossAxisAlignment
        alignment: view.alignment
        fill: view.fill
        border: view.border
        borderWidth: view.borderWidth
        radius: view.radius
        shape: view.shape
        material: view.material
        effects: identityEffects(view.effects)
        clipContent: view.clipContent
        content: view.content
        color: view.color
        size: view.size
        weight: view.weight
