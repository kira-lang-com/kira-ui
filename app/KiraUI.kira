import KiraUIFoundation

function RunWidgetApp(root: Widget) {
    RunKiraApp(KiraUIApp(
        name: "Kira UI",
        content: root
    ))
    return
}

function RunKiraApp(app: KiraUIApp) {
    let ignoredTitle = app.name.count
    let root = app.content
    let context = KiraUIFoundation.FoundationUiContext {}
    let view = root.lower(context)
    RunFoundationApp(move view)
    let ignored = ignoredTitle + 0
    return
}
